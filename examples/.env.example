# Copy to ~/.openclaw/.env and fill in real values. NEVER commit the real .env.
#
# openclaw.json references these by name (e.g. "$DEEPSEEK_API_KEY"); the gateway
# loads this file at startup and interpolates the values. See docs/03-config-files.md.

# --- Model providers ---
GEMINI_API_KEY=your-gemini-key
DEEPSEEK_API_KEY=your-deepseek-key
HF_TOKEN=hf_your_huggingface_token          # raw token only — do NOT prefix with "Bearer"

# --- Skills ---
TRANSCRIPT_API_KEY=your-transcriptapi-key   # for youtube-full / youtube-watcher (https://transcriptapi.com/signup)

# --- Gateway ---
OPENCLAW_GATEWAY_TOKEN=your-long-random-gateway-token

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token

# --- Web search ---
BRAVE_API_KEY=your-brave-search-key         # referenced by plugins.brave (NOT a Telegram var)
